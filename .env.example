# ---------------------------------------------------------------------------
# Altech — environment variables
# Copy to `.env` for local dev. On Vercel, set these in Project → Settings →
# Environment Variables.
# ---------------------------------------------------------------------------

# Postgres connection.
#  - Local dev: the Docker container -> postgres://postgres:postgres@localhost:5432/altech
#  - Production (Supabase): use the *Transaction* connection pooler (port 6543)
#    and append ?pgbouncer=true . Serverless MUST use the pooler, never the
#    direct 5432 connection.
#    e.g. postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URI=postgres://postgres:postgres@localhost:5432/altech

# Optional: direct (non-pooled) connection, port 5432. Used for running
# migrations from CI/local. Supabase: ...pooler.supabase.com:5432/postgres
# DATABASE_URI_DIRECT=

# Payload secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Public site URL (used by Payload for absolute URLs / admin). Production:
# https://<your-domain> ; local: http://localhost:3000
# NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Media storage — Supabase Storage (S3-compatible). Leave blank locally to use
# disk storage. Set all of these in production so uploads persist on Vercel.
# Get them in Supabase: Storage → S3 Connection (endpoint + region) and
# Project Settings → Storage → S3 access keys (access key id + secret).
# ---------------------------------------------------------------------------
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
